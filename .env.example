TELEGRAM_BOT_TOKEN=your_telegram_bot_token
DATABASE_PATH=./database/ecommerce.db
PORT=3000
NODE_ENV=development
ADMIN_ID=your_telegram_admin_id

# Payment QRIS otomatis seperti contoh BotZIVPN
PAYMENT=GOPAY
GOPAY_KEY=isi_token_gopay_kamu
GOPAY_QRIS_GENERATE_URL=https://v1-gateway.autogopay.site/qris/generate
GOPAY_QRIS_STATUS_URL=https://v1-gateway.autogopay.site/qris/status
QRIS_EXPIRED_MINUTES=10
QRIS_CHECK_INTERVAL_MS=5000
PAYMENT_REQUEST_TIMEOUT=10000
PAYMENT_NOTE=Scan QRIS, bayar sesuai nominal, lalu tunggu bot memverifikasi pembayaran otomatis.

# Hubungi Admin
ADMIN_DISPLAY_NAME=
ADMIN_USERNAME=
ADMIN_CONTACT_URL=
ADMIN_CONTACT_TEXT=Silakan hubungi admin untuk bantuan pembayaran, kendala produk, atau pertanyaan sebelum membeli.

# Backup otomatis
BACKUP_AUTO_ENABLED=true
BACKUP_TIME=00:00
BACKUP_TIMEZONE=Asia/Jakarta
BACKUP_KEEP_LOCAL=14
BACKUP_INCLUDE_ENV=true

# Multi-admin untuk backup, notifikasi order, notifikasi error
# ADMIN_ID tetap admin utama. ADMIN_IDS opsional untuk admin tambahan, pisahkan dengan koma.
ADMIN_IDS=

# QRIS expired: edit = caption QRIS diubah jadi expired, delete = pesan QRIS dihapus
QRIS_EXPIRED_ACTION=edit

# Maintenance default off. Bisa diubah dari /admin atau command maintenance_on / maintenance_off
MAINTENANCE_MODE=off

# Production features
PRODUCT_PAGE_SIZE=6
PAYMENT_REMINDER_AFTER_MINUTES=5
PAYMENT_REMINDER_INTERVAL_MS=120000
PM2_APP_NAME=ecommerce-bot

# Broadcast
BROADCAST_DELAY_MS=80

# Pre Order / request produk yang belum tersedia
PREORDER_PRICE=50000

# Pre Order Advanced
PREORDER_MIN_TEXT_LENGTH=20
PREORDER_MAX_REVISION=1
PREORDER_QUOTE_EXPIRED_HOURS=24
PREORDER_QUOTE_EXPIRE_CHECK_MS=300000

# Auto-cleanup data lama
CLEANUP_AUTO_ENABLED=true
CLEANUP_INTERVAL_MS=21600000
CLEANUP_QRIS_DAYS=7
CLEANUP_CART_DAYS=14
CLEANUP_ERROR_LOG_DAYS=30
CLEANUP_AUDIT_LOG_DAYS=180
CLEANUP_DELIVERY_LOG_DAYS=180
CLEANUP_NOTIFICATION_DAYS=30
CLEANUP_REPORT_DAYS=30
CLEANUP_NOTIFY_ADMIN=false
